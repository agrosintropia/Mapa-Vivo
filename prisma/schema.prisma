// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  type          String   // condominio|parque|incorporadora
  city          String
  state         String
  biome         String
  area_hectares Float?
  boundary      Json?    // GeoJSON polygon optional
  created_at    DateTime @default(now())
  trees         Tree[]
  submissions   Submission[]
}

model Species {
  id                    String   @id @default(uuid())
  common_name           String
  scientific_name       String
  family                String
  biome                 String[]
  strata                String   // emergente|alto|medio|baixo|arbustivo
  description           String?
  ecological_function   String?
  fruiting_season       String?
  fauna_attracted       String?
  subclasses            String[]
  default_carbon_factor Float?
  trees                 Tree[]
}

model Tree {
  id           String    @id @default(uuid())
  project_id   String
  species_id   String
  lat          Float
  lng          Float
  dbh_cm       Float?
  height_m     Float?
  planted_date DateTime?
  status       String    @default("viva")         // viva|doente|em_tratamento|morta|removida
  reliability  String    @default("pendente")     // validado_tecnico|pendente|declarado_gestor
  photo_url    String?
  qr_slug      String    @unique
  created_at   DateTime  @default(now())
  project      Project   @relation(fields: [project_id], references: [id])
  species      Species   @relation(fields: [species_id], references: [id])
  events       TreeEvent[]
}

model TreeEvent {
  id          String   @id @default(uuid())
  tree_id     String
  type        String   // plantio|atualizacao_estado|poda|validacao|observacao
  description String?
  photo_url   String?
  author_role String   // gestor|tecnico
  created_at  DateTime @default(now())
  tree        Tree     @relation(fields: [tree_id], references: [id])
}

model Submission {
  id               String   @id @default(uuid())
  project_id       String
  submitted_by     String
  species_guess_id String?
  lat              Float
  lng              Float
  photo_url        String?
  notes            String?
  status           String   @default("pendente") // pendente|aprovada|rejeitada|mais_info
  reviewer_id      String?
  created_at       DateTime @default(now())
  project          Project  @relation(fields: [project_id], references: [id])
}

model Profile {
  id         String  @id
  name       String
  role       String  // morador|gestor|tecnico
  project_id String?
}
